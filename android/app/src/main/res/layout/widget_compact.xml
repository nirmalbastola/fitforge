<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="14dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="FitForge"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        android:letterSpacing="0.05" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:layout_marginTop="6dp">

        <TextView
            android:id="@+id/compact_streak_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="34sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/compact_streak_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="this week"
            android:textColor="#A0A0A0"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/compact_total_volume"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 kg total"
            android:textColor="#FF8A2A"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <Button
        android:id="@+id/compact_start_btn"
        android:layout_width="match_parent"
        android:layout_height="38dp"
        android:text="Start Workout"
        android:textColor="#FFFFFF"
        android:textAllCaps="false"
        android:textSize="13sp"
        android:textStyle="bold"
        android:background="@drawable/widget_button_primary" />
</LinearLayout>
